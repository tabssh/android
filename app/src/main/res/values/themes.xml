<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    
    <!-- Base theme - Light -->
    <style name="Theme.TabSSH" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_500</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/primary_100</item>
        <item name="colorOnPrimaryContainer">@color/primary_900</item>

        <item name="colorSecondary">@color/secondary_500</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/secondary_100</item>
        <item name="colorOnSecondaryContainer">@color/secondary_900</item>

        <item name="colorTertiary">@color/info</item>
        <item name="colorOnTertiary">@color/white</item>

        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        <item name="colorErrorContainer">@color/error_dark</item>

        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <item name="android:statusBarColor">@color/primary_600</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Anchor the legacy textColor* attrs so layouts that reference
             ?android:attr/textColorPrimary etc. always get our verified
             contrast palette, not whatever the system's DayNight defaults
             pick. Without this, several section titles render as a tint
             far lighter than intended (Issue #35). -->
        <item name="android:textColorPrimary">@color/on_surface</item>
        <item name="android:textColorSecondary">@color/on_surface_variant</item>
        <item name="android:textColorTertiary">@color/gray_600</item>
        <item name="android:textColorHint">@color/gray_500</item>
        
        <!-- Custom attributes -->
        <item name="terminalBackgroundColor">@color/terminal_background</item>
        <item name="terminalTextColor">@color/terminal_foreground</item>
        <item name="tabBackgroundColor">@color/tab_background</item>
        <item name="tabTextColor">@color/tab_text</item>
        <item name="connectionStatusConnected">@color/connected</item>
        <item name="connectionStatusConnecting">@color/connecting</item>
        <item name="connectionStatusDisconnected">@color/disconnected</item>
        <item name="connectionStatusError">@color/connection_error</item>
    </style>
    
    <!-- Dark theme — force dark unconditionally. Was DayNight parent before
         which caused Issue #35: with system in light mode, DayNight handed us
         a LIGHT background but our explicit dark text-color overrides won,
         producing light-on-light text. The Dark theme is meant to look dark
         regardless of the system setting, so use Material3.Dark as parent. -->
    <style name="Theme.TabSSH.Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_400</item>
        <item name="colorOnPrimary">@color/primary_900</item>
        <item name="colorPrimaryContainer">@color/primary_800</item>
        <item name="colorOnPrimaryContainer">@color/primary_100</item>
        
        <item name="colorSecondary">@color/secondary_400</item>
        <item name="colorOnSecondary">@color/secondary_900</item>
        <item name="colorSecondaryContainer">@color/secondary_800</item>
        <item name="colorOnSecondaryContainer">@color/secondary_100</item>
        
        <item name="colorTertiary">@color/info</item>
        <item name="colorOnTertiary">@color/white</item>
        
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_dark</item>
        
        <item name="colorOutline">@color/outline_dark</item>
        <item name="colorOutlineVariant">@color/outline_variant_dark</item>
        
        <item name="android:statusBarColor">@color/surface_dark</item>
        <item name="android:navigationBarColor">@color/surface_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Anchor textColor* for the dark theme too (Issue #35). -->
        <item name="android:textColorPrimary">@color/on_surface_dark</item>
        <item name="android:textColorSecondary">@color/on_surface_variant_dark</item>
        <item name="android:textColorTertiary">@color/gray_400</item>
        <item name="android:textColorHint">@color/gray_500</item>

        <!-- Custom attributes -->
        <item name="terminalBackgroundColor">@color/terminal_background</item>
        <item name="terminalTextColor">@color/terminal_foreground</item>
        <item name="tabBackgroundColor">@color/surface_variant_dark</item>
        <item name="tabTextColor">@color/on_surface_dark</item>
        <item name="connectionStatusConnected">@color/connected</item>
        <item name="connectionStatusConnecting">@color/connecting</item>
        <item name="connectionStatusDisconnected">@color/disconnected</item>
        <item name="connectionStatusError">@color/connection_error</item>
    </style>
    
    <!-- High contrast theme for accessibility -->
    <style name="Theme.TabSSH.HighContrast" parent="Theme.TabSSH">
        <item name="colorPrimary">@color/black</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/black</item>
        <item name="terminalBackgroundColor">@color/high_contrast_background</item>
        <item name="terminalTextColor">@color/high_contrast_foreground</item>
    </style>
    
    <!-- Fullscreen theme for terminal -->
    <style name="Theme.TabSSH.Fullscreen" parent="Theme.TabSSH">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>
    
    <!-- Settings theme -->
    <style name="Theme.TabSSH.Settings" parent="Theme.TabSSH">
        <!-- Settings specific customizations -->
    </style>
    
    <!-- Widget styles -->
    <style name="Widget.TabSSH" parent="@android:style/Widget" />
    
    <style name="Widget.TabSSH.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/primary_500</item>
    </style>
    
    <style name="Widget.TabSSH.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/primary_500</item>
        <item name="strokeColor">@color/primary_500</item>
    </style>
    
    <style name="Widget.TabSSH.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary_500</item>
        <item name="hintTextColor">@color/primary_500</item>
    </style>
    
    <!-- Tab styles -->
    <style name="Widget.TabSSH.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabBackground">@drawable/tab_background_selector</item>
        <item name="tabTextColor">@color/tab_text</item>
        <item name="tabSelectedTextColor">@color/primary_500</item>
        <item name="tabIndicatorColor">@color/primary_500</item>
        <item name="tabIndicatorHeight">3dp</item>
    </style>
    
    <!-- Terminal specific styles -->
    <style name="Widget.TabSSH.Terminal">
        <item name="android:background">@color/terminal_background</item>
        <item name="android:textColor">@color/terminal_foreground</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>
    
    <!-- Toolbar styles -->
    <style name="Widget.TabSSH.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">@color/primary_100</item>
        <item name="navigationIconTint">@color/white</item>
    </style>

    <!-- Compact toolbar title -->
    <style name="TextAppearance.TabSSH.Toolbar.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Compact navigation drawer style -->
    <style name="Widget.TabSSH.NavigationView" parent="Widget.Material3.NavigationView">
        <item name="itemIconSize">20dp</item>
        <item name="itemIconPadding">8dp</item>
        <item name="itemVerticalPadding">4dp</item>
        <item name="itemHorizontalPadding">12dp</item>
        <item name="itemTextAppearance">@style/TextAppearance.TabSSH.NavigationItem</item>
    </style>

    <!-- Compact navigation item text -->
    <style name="TextAppearance.TabSSH.NavigationItem" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">13sp</item>
    </style>
    
    <!-- FAB styles -->
    <style name="Widget.TabSSH.FloatingActionButton" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary_500</item>
        <item name="tint">@color/white</item>
    </style>

    <!--
        Bulk-edit dialog styles (rewrite 2026-05-02). Apply semantics
        moved to value-presence — empty input = no change — so there's
        no per-row apply switch any more. Sections are MaterialCardView
        with subtle outline, full-width inputs inside.
    -->
    <style name="BulkEdit" parent="" />

    <style name="BulkEdit.Section" parent="Widget.Material3.CardView.Outlined">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">12dp</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="BulkEdit.SectionInner">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="BulkEdit.SectionHeader">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:layout_marginBottom">10dp</item>
    </style>

    <style name="BulkEdit.SectionIcon">
        <item name="android:layout_width">18dp</item>
        <item name="android:layout_height">18dp</item>
        <item name="android:layout_marginEnd">8dp</item>
        <item name="tint">?attr/colorPrimary</item>
        <item name="android:importantForAccessibility">no</item>
    </style>

    <style name="BulkEdit.SectionTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textAppearance">?attr/textAppearanceLabelSmall</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <!-- Transparent activity theme for dialog-only activities (e.g. ConfirmDisconnectActivity).
         The window has a clear background so the notification shade / underlying app shows
         through while the AlertDialog is visible. backgroundDimEnabled darkens everything
         behind it so the dialog itself stands out clearly. -->
    <style name="Theme.TabSSH.Transparent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.6</item>
    </style>

    <style name="BulkEdit.Input" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="BulkEdit.Dropdown" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">8dp</item>
    </style>

    <style name="BulkEdit.InputEdit">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

</resources>