<?xml version="1.0" encoding="utf-8"?>
<!-- Edge-swipe reject feedback glow. Fades from the theme's primary color at
     full opacity down to fully transparent moving away from the screen edge.
     Shown briefly (see showSwipeEdgeRejectionFeedback() in
     TabTerminalActivity) when a mid-screen swipe is rejected by the
     edge-zone gate, so the rejection reads as a visible cue instead of a
     silent no-op. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="0"
        android:startColor="?attr/colorPrimary"
        android:endColor="@android:color/transparent" />
</shape>
