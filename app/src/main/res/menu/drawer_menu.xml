<?xml version="1.0" encoding="utf-8"?>
<!--
  Navigation drawer — items that are accessible via a main tab are NOT
  duplicated here; the drawer covers everything that has no natural tab home.

  Groups: Quick → Manage → Connect → Insights → Import/Export → Settings → Diagnostics
  Tabs handle: Frequent | Hosts | Identities | Stats | VMs
-->
<menu xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Quick: one-shot actions that don't live in any tab -->
    <group android:id="@+id/group_quick">
        <item
            android:id="@+id/nav_quick_connect"
            android:icon="@drawable/ic_flash"
            android:title="Quick Connect" />
    </group>

    <item android:title="Manage">
        <menu>
            <item
                android:id="@+id/nav_snippets"
                android:icon="@drawable/ic_code"
                android:title="Snippets" />
            <item
                android:id="@+id/nav_manage_groups"
                android:icon="@android:drawable/ic_menu_agenda"
                android:title="Groups" />
            <item
                android:id="@+id/nav_cloud_accounts"
                android:icon="@android:drawable/ic_menu_upload"
                android:title="Cloud Accounts" />
        </menu>
    </item>

    <item android:title="Connect">
        <menu>
            <item
                android:id="@+id/nav_port_forwarding"
                android:icon="@drawable/ic_forward"
                android:title="Port Forwarding" />
            <item
                android:id="@+id/nav_cluster_commands"
                android:icon="@android:drawable/ic_menu_share"
                android:title="Cluster Commands" />
        </menu>
    </item>

    <item android:title="Insights">
        <menu>
            <item
                android:id="@+id/nav_multi_dashboard"
                android:icon="@android:drawable/ic_menu_view"
                android:title="Multi-host Dashboard" />
            <item
                android:id="@+id/nav_connection_history"
                android:icon="@android:drawable/ic_menu_recent_history"
                android:title="Connection History" />
        </menu>
    </item>

    <item android:title="Import / Export">
        <menu>
            <item
                android:id="@+id/nav_import_ssh_config"
                android:icon="@android:drawable/ic_menu_upload"
                android:title="Import SSH Config" />
            <item
                android:id="@+id/nav_export_ssh_config"
                android:icon="@android:drawable/ic_menu_save"
                android:title="Export SSH Config" />
            <item
                android:id="@+id/nav_bulk_import"
                android:icon="@android:drawable/ic_menu_upload"
                android:title="Bulk Import (CSV / JSON / PuTTY / Terraform)" />
            <item
                android:id="@+id/nav_pair_from_desktop"
                android:icon="@android:drawable/ic_menu_camera"
                android:title="Pair from Desktop (QR)" />
            <item
                android:id="@+id/nav_import_connections"
                android:icon="@android:drawable/ic_menu_upload"
                android:title="Import Backup" />
            <item
                android:id="@+id/nav_export_connections"
                android:icon="@android:drawable/ic_menu_save"
                android:title="Export Backup" />
        </menu>
    </item>

    <group android:id="@+id/group_settings">
        <item
            android:id="@+id/nav_settings"
            android:icon="@drawable/ic_settings"
            android:title="Settings" />
    </group>

    <item android:title="Diagnostics">
        <menu>
            <item
                android:id="@+id/nav_copy_app_log"
                android:icon="@android:drawable/ic_menu_recent_history"
                android:title="Copy App Log (Safe to Share)" />
            <item
                android:id="@+id/nav_copy_debug_logs"
                android:icon="@android:drawable/ic_menu_info_details"
                android:title="Copy Debug Logs (Developer)" />
            <item
                android:id="@+id/nav_whats_new"
                android:icon="@drawable/ic_info"
                android:title="What's New" />
            <item
                android:id="@+id/nav_help"
                android:icon="@drawable/ic_help"
                android:title="Help" />
            <item
                android:id="@+id/nav_about"
                android:icon="@drawable/ic_info"
                android:title="About" />
        </menu>
    </item>

</menu>
