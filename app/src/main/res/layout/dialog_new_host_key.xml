<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/colorSurface"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Welcome Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:elevation="2dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="First Connection"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="#2E7D32"
                android:gravity="center"
                android:paddingBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This is the first time connecting to this server"
                android:textSize="13sp"
                android:textColor="#1B5E20"
                android:gravity="center"
                android:alpha="0.9" />

        </LinearLayout>

        <!-- Server Information Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="?attr/materialCardViewFilledStyle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Server"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/text_hostname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textColor="?attr/colorPrimary"
                    tools:text="example.com:22" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Key Information Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            style="?attr/materialCardViewOutlinedStyle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#E3F2FD">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Server Public Key"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:textColor="#1565C0"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/text_key_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:paddingBottom="8dp"
                    android:textColor="#0D47A1"
                    tools:text="Key Type: ssh-ed25519" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fingerprint:"
                    android:textSize="12sp"
                    android:textColor="#1565C0"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/text_fingerprint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:textIsSelectable="true"
                    android:background="#FFFFFF"
                    android:padding="8dp"
                    android:textColor="#000000"
                    tools:text="SHA256:abc123def456..." />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Security Guidance Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="?attr/materialCardViewElevatedStyle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@android:color/white">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Security Verification"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1976D2"
                    android:paddingBottom="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Please verify this fingerprint matches your server's key before connecting.\n\nYou can check this on your server by running:\nssh-keygen -lf /etc/ssh/ssh_host_*_key.pub"
                    android:textSize="13sp"
                    android:lineSpacingExtra="4dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="If you trust this server, click 'Trust &amp; Connect' to save the key and proceed."
                    android:textSize="12sp"
                    android:textColor="#757575" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
