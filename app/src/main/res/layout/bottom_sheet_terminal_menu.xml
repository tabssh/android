<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <!-- Drag handle -->
        <View
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_bottom_sheet_handle" />

        <!-- Primary action: New Tab -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_new_tab"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp"
            android:text="New Tab…"
            app:icon="@drawable/ic_add"
            app:iconGravity="start"
            app:iconPadding="8dp" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Open Tabs section header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="OPEN TABS"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tabs_recycler_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Terminal section header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="TERMINAL"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_toggle_system_keyboard"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Toggle System Keyboard"
            app:icon="@drawable/ic_keyboard"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_toggle_key_bar"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Hide Key Bar"
            app:icon="@drawable/ic_keyboard"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_find_in_scrollback"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Find in Scrollback…"
            app:icon="@drawable/ic_search"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_snippets"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Snippets…"
            app:icon="@drawable/ic_bookmark"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_toggle_recording"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Start Recording"
            app:icon="@drawable/ic_radio_checked"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Session section header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="SESSION"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cluster_broadcast"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Broadcast to All Tabs…"
            app:icon="@drawable/ic_flash"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_port_forwarding"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Port Forwarding"
            app:icon="@drawable/ic_interface"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_session"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Share Session"
            app:icon="@drawable/ic_share"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_close_tab"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Close Current Tab"
            app:icon="@drawable/ic_close"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_disconnect_all"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Disconnect All"
            app:icon="@drawable/ic_disconnect"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Settings -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_settings"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:paddingStart="16dp"
            android:gravity="start|center_vertical"
            android:text="Settings"
            app:icon="@drawable/ic_settings_general"
            app:iconGravity="start"
            app:iconPadding="12dp"
            app:iconSize="20dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
