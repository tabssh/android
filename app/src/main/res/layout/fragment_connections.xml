<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main Content with Search -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Toolbar with Sort + Bulk Edit. The menu is inflated via the
             fragment's MenuProvider (lifecycle-aware) — DON'T set
             `app:menu` here, that double-inflates and gives you two of
             every icon. -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar_connections"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/colorSurface"
            app:title="Connections" />

        <!-- Search Bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/space_md"
            app:cardElevation="2dp"
            app:cardCornerRadius="8dp">

            <androidx.appcompat.widget.SearchView
                android:id="@+id/search_view"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                app:queryHint="Search connections..."
                app:iconifiedByDefault="false"
                android:background="?attr/colorSurface" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Issue #165 — Active sessions strip. Visible only when there
             are running tabs. Header + horizontal RecyclerView so users
             can jump back into a live session without scrolling through
             every saved profile. The container is collapsed to height=0
             when empty so the empty Connections state still centers
             properly. -->
        <LinearLayout
            android:id="@+id/active_sessions_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/active_sessions_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_md"
                android:layout_marginEnd="@dimen/space_md"
                android:layout_marginTop="@dimen/space_sm"
                android:text="Active Sessions"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:textSize="14sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_active_sessions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/space_md"
                android:paddingEnd="@dimen/space_md"
                android:paddingTop="@dimen/space_xs"
                android:paddingBottom="@dimen/space_sm"
                android:clipToPadding="false"
                tools:listitem="@layout/item_active_session"
                tools:itemCount="3" />

        </LinearLayout>

        <!-- All Connections RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_connections"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:clipToPadding="false"
            tools:listitem="@layout/item_connection"
            tools:itemCount="10" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/layout_empty_connections"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="@dimen/space_xl"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💻"
                android:textSize="64sp"
                android:paddingBottom="@dimen/space_md" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No Connections"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:textColor="?attr/colorOnSurface"
                android:paddingBottom="@dimen/space_sm" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tap the + button to add your first SSH server"
                android:textSize="14sp"
                android:gravity="center"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
