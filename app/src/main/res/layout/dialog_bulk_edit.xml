<?xml version="1.0" encoding="utf-8"?>
<!--
    Bulk-edit dialog (rewrite, 2026-05-02).

    Layout philosophy:
      * One control per row, full row width. No more side-by-side input +
        "apply" switch — the value-presence model handles apply implicitly:
          - Text fields empty → ignored. Non-empty → applied.
          - Dropdowns blank → ignored. "(Clear …)" → write null.
            Any other selection → applied.
          - Tri-state booleans default to "Don't change". Off / On are
            explicit choices.
      * Section cards (Connection / Behavior / Terminal / Advanced) use
        an outlined MaterialCardView with a small icon + ALL CAPS subhead.
        Cards stack vertically; no per-section collapse — easier to scan
        on small screens than nested accordions.
      * Header: selected count + Reset button on top, live "N changes"
        summary right under it. Both update as the user edits.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbarStyle="outsideOverlay">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- ───────────────────────── HEADER ───────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="2dp">

            <TextView
                android:id="@+id/text_selected_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 connections selected"
                android:textColor="?attr/colorOnSurface"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_reset_all"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="64dp"
                android:minHeight="36dp"
                android:text="Reset" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_apply_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No changes yet — fill in any field below to enqueue it"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:layout_marginBottom="16dp" />

        <!-- ─────────────────────── CONNECTION ─────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            style="@style/BulkEdit.Section">

            <LinearLayout style="@style/BulkEdit.SectionInner">

                <LinearLayout style="@style/BulkEdit.SectionHeader">
                    <ImageView
                        style="@style/BulkEdit.SectionIcon"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_connection" />
                    <TextView
                        style="@style/BulkEdit.SectionTitle"
                        android:text="CONNECTION" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_username"
                    style="@style/BulkEdit.Input"
                    app:startIconDrawable="@drawable/ic_person"
                    android:hint="Username">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_username"
                        style="@style/BulkEdit.InputEdit"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_port"
                    style="@style/BulkEdit.Input"
                    android:hint="Port">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_port"
                        style="@style/BulkEdit.InputEdit"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_group"
                    style="@style/BulkEdit.Dropdown"
                    app:startIconDrawable="@drawable/ic_folder"
                    android:hint="Assign to group">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdown_group"
                        style="@style/BulkEdit.InputEdit"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_identity"
                    style="@style/BulkEdit.Dropdown"
                    app:startIconDrawable="@drawable/ic_security"
                    android:hint="Use identity">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdown_identity"
                        style="@style/BulkEdit.InputEdit"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_timeout"
                    style="@style/BulkEdit.Input"
                    android:hint="Connection timeout (seconds)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_timeout"
                        style="@style/BulkEdit.InputEdit"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ──────────────────────── BEHAVIOR ──────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            style="@style/BulkEdit.Section">

            <LinearLayout style="@style/BulkEdit.SectionInner">

                <LinearLayout style="@style/BulkEdit.SectionHeader">
                    <ImageView
                        style="@style/BulkEdit.SectionIcon"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_settings_general" />
                    <TextView
                        style="@style/BulkEdit.SectionTitle"
                        android:text="BEHAVIOR" />
                </LinearLayout>

                <include
                    android:id="@+id/row_compression"
                    layout="@layout/include_bulk_edit_tristate" />

                <include
                    android:id="@+id/row_agent_fwd"
                    layout="@layout/include_bulk_edit_tristate" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ──────────────────────── TERMINAL ──────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            style="@style/BulkEdit.Section">

            <LinearLayout style="@style/BulkEdit.SectionInner">

                <LinearLayout style="@style/BulkEdit.SectionHeader">
                    <ImageView
                        style="@style/BulkEdit.SectionIcon"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_terminal" />
                    <TextView
                        style="@style/BulkEdit.SectionTitle"
                        android:text="TERMINAL" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_terminal_type"
                    style="@style/BulkEdit.Dropdown"
                    app:startIconDrawable="@drawable/ic_terminal"
                    android:hint="Terminal type">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdown_terminal_type"
                        style="@style/BulkEdit.InputEdit"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_color_tag"
                    style="@style/BulkEdit.Dropdown"
                    app:startIconDrawable="@drawable/ic_star_outline"
                    android:hint="Color tag">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/dropdown_color_tag"
                        style="@style/BulkEdit.InputEdit"
                        android:inputType="none" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ──────────────────────── ADVANCED ──────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            style="@style/BulkEdit.Section">

            <LinearLayout style="@style/BulkEdit.SectionInner">

                <LinearLayout style="@style/BulkEdit.SectionHeader">
                    <ImageView
                        style="@style/BulkEdit.SectionIcon"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_flash" />
                    <TextView
                        style="@style/BulkEdit.SectionTitle"
                        android:text="ADVANCED" />
                </LinearLayout>

                <include
                    android:id="@+id/row_x11"
                    layout="@layout/include_bulk_edit_tristate" />

                <include
                    android:id="@+id/row_mosh"
                    layout="@layout/include_bulk_edit_tristate" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/layout_post_connect"
                    style="@style/BulkEdit.Input"
                    app:startIconDrawable="@drawable/ic_code"
                    android:hint="Post-connect script (one command per line)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_post_connect"
                        style="@style/BulkEdit.InputEdit"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:maxLines="4"
                        android:gravity="top|start" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
