<?xml version="1.0" encoding="utf-8"?>
<!--
    Bulk-edit dialog (rewrite, 2026-04-29).

    Layout philosophy:
      * Sections (Connection / Behavior / Terminal / Advanced) are
        labelled with an icon + small caps subhead and separated with
        outline-variant dividers so the eye can group fields.
      * Every "value" field has an "Apply this field" SwitchMaterial
        on the right. When the switch is OFF the row fades (alpha 0.45)
        and the input is non-interactable. The fragment auto-flips the
        switch ON when the user actually edits the field's value, so
        the manual checkbox dance from the old layout is gone.
      * Boolean fields use a tri-state MaterialButtonToggleGroup with
        three buttons: "—" (don't change, default), "Off", "On". This
        replaces the awkward old "outer checkbox enables, inner switch
        picks value" pattern with a single explicit choice.
      * The header shows a live "N changes will apply to M connections"
        count and a Reset All button.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- ─────────────────────── HEADER ─────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/text_selected_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 connections selected"
                android:textColor="?attr/colorPrimary"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/button_reset_all"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="36dp"
                android:text="Reset" />
        </LinearLayout>

        <TextView
            android:id="@+id/text_apply_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No changes selected — flip a switch or pick a value"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:layout_marginBottom="20dp" />

        <!-- ──────────────────── CONNECTION ──────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_connection"
                android:layout_marginEnd="8dp"
                app:tint="?attr/colorPrimary"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CONNECTION"
                android:textColor="?attr/colorPrimary"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textStyle="bold"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- Username -->
        <LinearLayout
            android:id="@+id/row_username"
            style="@style/BulkEdit.FieldRow">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_username"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Username"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:startIconDrawable="@drawable/ic_person">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="text" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/check_username"
                style="@style/BulkEdit.ApplySwitch" />
        </LinearLayout>

        <!-- Port -->
        <LinearLayout
            android:id="@+id/row_port"
            style="@style/BulkEdit.FieldRow">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_port"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Port"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_port"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/check_port"
                style="@style/BulkEdit.ApplySwitch" />
        </LinearLayout>

        <!-- Group -->
        <LinearLayout
            android:id="@+id/row_group"
            style="@style/BulkEdit.FieldRow">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_group"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Assign to group"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:startIconDrawable="@drawable/ic_folder">

                <AutoCompleteTextView
                    android:id="@+id/dropdown_group"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/check_group"
                style="@style/BulkEdit.ApplySwitch" />
        </LinearLayout>

        <!-- Identity -->
        <LinearLayout
            android:id="@+id/row_identity"
            style="@style/BulkEdit.FieldRow">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_identity"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Use identity"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:startIconDrawable="@drawable/ic_security">

                <AutoCompleteTextView
                    android:id="@+id/dropdown_identity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/check_identity"
                style="@style/BulkEdit.ApplySwitch" />
        </LinearLayout>

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <!-- ───────────────────── BEHAVIOR ───────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_settings_general"
                android:layout_marginEnd="8dp"
                app:tint="?attr/colorPrimary"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BEHAVIOR"
                android:textColor="?attr/colorPrimary"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textStyle="bold"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- Connection timeout -->
        <LinearLayout
            android:id="@+id/row_timeout"
            style="@style/BulkEdit.FieldRow">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_timeout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Connection timeout (seconds)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_timeout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/check_timeout"
                style="@style/BulkEdit.ApplySwitch" />
        </LinearLayout>

        <!-- Tri-state booleans: keepalive, compression, agent fwd -->
        <include
            android:id="@+id/row_keepalive"
            layout="@layout/include_bulk_edit_tristate" />
        <include
            android:id="@+id/row_compression"
            layout="@layout/include_bulk_edit_tristate" />
        <include
            android:id="@+id/row_agent_fwd"
            layout="@layout/include_bulk_edit_tristate" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <!-- ───────────────────── TERMINAL ───────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_terminal"
                android:layout_marginEnd="8dp"
                app:tint="?attr/colorPrimary"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TERMINAL"
                android:textColor="?attr/colorPrimary"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textStyle="bold"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- Terminal type -->
        <LinearLayout
            android:id="@+id/row_terminal_type"
            style="@style/BulkEdit.FieldRow">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_terminal_type"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Terminal type"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:startIconDrawable="@drawable/ic_terminal">

                <AutoCompleteTextView
                    android:id="@+id/dropdown_terminal_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/check_terminal_type"
                style="@style/BulkEdit.ApplySwitch" />
        </LinearLayout>

        <!-- Color tag -->
        <LinearLayout
            android:id="@+id/row_color_tag"
            style="@style/BulkEdit.FieldRow">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_color_tag"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Color tag"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                app:startIconDrawable="@drawable/ic_star_outline">

                <AutoCompleteTextView
                    android:id="@+id/dropdown_color_tag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/check_color_tag"
                style="@style/BulkEdit.ApplySwitch" />
        </LinearLayout>

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp" />

        <!-- ───────────────────── ADVANCED ───────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_flash"
                android:layout_marginEnd="8dp"
                app:tint="?attr/colorPrimary"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ADVANCED"
                android:textColor="?attr/colorPrimary"
                android:textAppearance="?attr/textAppearanceLabelSmall"
                android:textStyle="bold"
                android:letterSpacing="0.08" />
        </LinearLayout>

        <!-- Tri-state bools: X11, Mosh -->
        <include
            android:id="@+id/row_x11"
            layout="@layout/include_bulk_edit_tristate" />
        <include
            android:id="@+id/row_mosh"
            layout="@layout/include_bulk_edit_tristate" />

        <!-- Post-connect script -->
        <LinearLayout
            android:id="@+id/row_post_connect"
            style="@style/BulkEdit.FieldRow">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/layout_post_connect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Post-connect commands (one per line)"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:startIconDrawable="@drawable/ic_code">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edit_post_connect"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:minLines="2"
                    android:maxLines="4"
                    android:gravity="top|start" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/check_post_connect"
                style="@style/BulkEdit.ApplySwitch" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
