<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="Connection Defaults"
        android:key="category_connection_defaults">

        <EditTextPreference
            android:key="default_username"
            android:title="Default Username"
            android:summary="Username for new connections and quick connect"
            android:defaultValue="root"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="default_port"
            android:title="Default Port"
            android:summary="SSH port number"
            android:defaultValue="22"
            android:inputType="number"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="connect_timeout"
            android:title="Connection Timeout"
            android:summary="Seconds to wait for connection"
            android:defaultValue="15"
            android:inputType="number"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Connection Behavior"
        android:key="category_connection_behavior">

        <!-- Keep-alive is always on at the SSH layer (10s ServerAliveInterval,
             3 missed before disconnect — see SSHConnection.configureSession).
             User-facing toggle removed to stop the appearance of a setting
             that does nothing on mobile. -->

        <SwitchPreferenceCompat
            android:key="compression_enabled"
            android:title="Compression"
            android:summary="Enable SSH compression (default for new connections)"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="auto_reconnect"
            android:title="Auto Reconnect"
            android:summary="Automatically reconnect on connection loss"
            android:defaultValue="false" />

        <EditTextPreference
            android:key="server_alive_interval"
            android:title="Keepalive Interval"
            android:summary="Seconds between server-alive pings (default 60)"
            android:defaultValue="60"
            android:inputType="number"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            android:key="x11_forwarding_default"
            android:title="X11 Forwarding"
            android:summary="Forward X11 display by default for new connections"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            android:key="agent_forwarding_default"
            android:title="SSH Agent Forwarding"
            android:summary="Forward SSH agent by default for new connections"
            android:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Multiplexer Prefixes"
        android:key="category_multiplexer_prefixes">

        <EditTextPreference
            android:key="multiplexer_custom_prefix_tmux"
            android:title="tmux prefix"
            android:summary="Prefix key sent by the PRE keyboard button when tmux is active"
            android:defaultValue="C-b"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="multiplexer_custom_prefix_screen"
            android:title="screen prefix"
            android:summary="Prefix key sent by the PRE keyboard button when screen is active"
            android:defaultValue="C-a"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="multiplexer_custom_prefix_zellij"
            android:title="zellij prefix"
            android:summary="Prefix key sent by the PRE keyboard button when zellij is active"
            android:defaultValue="C-g"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Mosh"
        android:key="category_mosh">

        <!-- The mosh server command is now configured per-connection via a
             dropdown in the connection editor. This global preference is kept
             for users who entered a custom command before per-connection support
             was added; it is no longer read by the app. -->
        <EditTextPreference
            android:key="mosh_server_command"
            android:title="Global Mosh Server Command (legacy)"
            android:summary="Superseded by the per-connection command picker. No longer used."
            android:defaultValue="mosh-server new -l LANG=en_US.UTF-8"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

</PreferenceScreen>
