<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="Connection Defaults"
        android:key="category_connection_defaults">

        <EditTextPreference
            android:key="default_username"
            android:title="Default Username"
            android:summary="Username for new connections and quick connect"
            android:defaultValue="root"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="default_port"
            android:title="Default Port"
            android:summary="SSH port number"
            android:defaultValue="22"
            android:inputType="number"
            app:useSimpleSummaryProvider="true" />

        <EditTextPreference
            android:key="connect_timeout"
            android:title="Connection Timeout"
            android:summary="Seconds to wait for connection"
            android:defaultValue="15"
            android:inputType="number"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Connection Behavior"
        android:key="category_connection_behavior">

        <!-- Keep-alive is always on at the SSH layer (10s ServerAliveInterval,
             3 missed before disconnect — see SSHConnection.configureSession).
             User-facing toggle removed to stop the appearance of a setting
             that does nothing on mobile. -->

        <SwitchPreferenceCompat
            android:key="compression_enabled"
            android:title="Compression"
            android:summary="Enable SSH compression"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="auto_reconnect"
            android:title="Auto Reconnect"
            android:summary="Automatically reconnect on connection loss"
            android:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Mosh Configuration"
        android:key="category_mosh">

        <EditTextPreference
            android:key="mosh_server_command"
            android:title="Mosh Server Command"
            android:summary="Custom command for mosh-server"
            android:defaultValue="mosh-server new -s -l LANG=en_US.UTF-8"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

</PreferenceScreen>
