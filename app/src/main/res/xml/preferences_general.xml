<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="Appearance"
        android:key="category_appearance">

        <ListPreference
            android:key="app_theme"
            android:title="App Theme"
            android:summary="Choose light or dark theme"
            android:entries="@array/theme_entries"
            android:entryValues="@array/theme_values"
            android:defaultValue="dark"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:key="app_language"
            android:title="Language"
            android:summary="Application language"
            android:entries="@array/language_entries"
            android:entryValues="@array/language_values"
            android:defaultValue="en"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Behavior"
        android:key="category_behavior">

        <SwitchPreferenceCompat
            android:key="swipe_between_tabs"
            android:title="Swipe Between Tabs"
            android:summary="Swipe left/right to switch between SSH sessions"
            android:defaultValue="true" />

        <!-- Wave 3.7 — bottom nav visibility -->
        <SwitchPreferenceCompat
            android:key="show_bottom_nav"
            android:title="Show bottom nav bar"
            android:summary="Compact 48dp nav with Kbd · Snip · Files · Paste · Menu (uncheck for the legacy edge-tap behaviour)"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="confirm_exit"
            android:title="Confirm on exit"
            android:summary="Ask for confirmation before exiting"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            android:key="keep_screen_on"
            android:title="Keep screen on"
            android:summary="Prevent screen from sleeping during connections"
            android:defaultValue="false" />

        <ListPreference
            android:key="general_startup_behavior"
            android:title="Startup behavior"
            android:summary="Which screen to show on app launch"
            android:entries="@array/startup_entries"
            android:entryValues="@array/startup_values"
            android:defaultValue="connections"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            android:key="ui_confirm_tab_close"
            android:title="Confirm tab close"
            android:summary="Ask before closing a tab with an active connection"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="ui_max_tabs"
            android:title="Max open tabs"
            android:summary="Refuse new tabs once this limit is reached"
            android:defaultValue="20"
            android:inputType="number"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Accessibility"
        android:key="category_accessibility">

        <SwitchPreferenceCompat
            android:key="accessibility_high_contrast"
            android:title="High contrast"
            android:summary="Increase contrast for low-vision users"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            android:key="accessibility_large_touch_targets"
            android:title="Large touch targets"
            android:summary="Increase the size of buttons and tap targets"
            android:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Notifications"
        android:key="category_notifications">

        <SwitchPreferenceCompat
            android:key="notifications_enabled"
            android:title="Enable Notifications"
            android:summary="Show notifications for connections, errors, and file transfers"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="show_connection_notifications"
            android:title="Connection Notifications"
            android:summary="Show when connecting/disconnecting"
            android:defaultValue="true"
            android:dependency="notifications_enabled" />

        <SwitchPreferenceCompat
            android:key="show_error_notifications"
            android:title="Error Notifications"
            android:summary="Show connection errors"
            android:defaultValue="true"
            android:dependency="notifications_enabled" />

        <SwitchPreferenceCompat
            android:key="show_file_transfer_notifications"
            android:title="File Transfer Notifications"
            android:summary="Show SFTP upload/download progress"
            android:defaultValue="true"
            android:dependency="notifications_enabled" />

        <SwitchPreferenceCompat
            android:key="notification_vibrate"
            android:title="Vibrate"
            android:summary="Vibrate for connection and error notifications"
            android:defaultValue="true"
            android:dependency="notifications_enabled" />

        <Preference
            android:key="open_system_notification_settings"
            android:title="System Notification Settings"
            android:summary="Configure channels, sounds, and priority in Android settings" />

    </PreferenceCategory>

</PreferenceScreen>
