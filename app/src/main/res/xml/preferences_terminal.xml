<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="Appearance"
        android:key="category_terminal_appearance">

        <ListPreference
            android:key="terminal_theme"
            android:title="Theme / Colors"
            android:summary="Terminal color scheme"
            android:entries="@array/terminal_theme_entries"
            android:entryValues="@array/terminal_theme_values"
            android:defaultValue="dracula"
            app:useSimpleSummaryProvider="true" />

        <Preference
            android:key="import_custom_theme"
            android:title="Import Custom Theme"
            android:summary="Load a JSON theme file" />

        <Preference
            android:key="export_current_theme"
            android:title="Export Current Theme"
            android:summary="Save current theme as JSON" />

        <ListPreference
            android:key="terminal_font"
            android:title="Font"
            android:summary="Monospace font family"
            android:entries="@array/terminal_font_entries"
            android:entryValues="@array/terminal_font_values"
            android:defaultValue="cascadia_code"
            app:useSimpleSummaryProvider="true" />

        <SeekBarPreference
            android:key="terminal_font_size"
            android:title="Font Size"
            android:summary="Terminal text size"
            android:defaultValue="14"
            android:max="32"
            android:min="8"
            app:showSeekBarValue="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Behavior"
        android:key="category_terminal_behavior">

        <ListPreference
            android:key="terminal_cursor_style"
            android:title="Cursor Style"
            android:summary="Cursor appearance"
            android:entries="@array/cursor_style_entries"
            android:entryValues="@array/cursor_style_values"
            android:defaultValue="block"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            android:key="terminal_cursor_blink"
            android:title="Cursor Blink"
            android:summary="Blinking cursor"
            android:defaultValue="true" />

        <EditTextPreference
            android:key="terminal_scrollback"
            android:title="Scrollback Buffer"
            android:summary="Lines in history (250 min, -1 unlimited)"
            android:defaultValue="-1"
            android:inputType="numberSigned"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            android:key="terminal_bell"
            android:title="Terminal Bell"
            android:summary="Audible bell on BEL character"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="terminal_bell_vibrate"
            android:title="Vibrate on Bell"
            android:summary="Vibrate device when BEL character received"
            android:defaultValue="true"
            android:dependency="terminal_bell" />

        <SwitchPreferenceCompat
            android:key="terminal_bell_visual"
            android:title="Flash on Bell"
            android:summary="Briefly invert terminal colors when BEL received"
            android:defaultValue="true"
            android:dependency="terminal_bell" />

        <SwitchPreferenceCompat
            android:key="terminal_word_wrap"
            android:title="Word Wrap"
            android:summary="Wrap long lines at the terminal width"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="terminal_copy_on_select"
            android:title="Copy on Select"
            android:summary="Auto-copy selected text to clipboard"
            android:defaultValue="false" />

        <SeekBarPreference
            android:key="terminal_line_spacing"
            android:title="Line Spacing"
            android:summary="Vertical spacing between lines (100% = normal)"
            android:defaultValue="120"
            android:max="200"
            android:min="100"
            app:showSeekBarValue="true" />

        <SwitchPreferenceCompat
            android:key="ui_fullscreen_mode"
            android:title="Fullscreen Terminal"
            android:summary="Hide status &amp; navigation bars while in a tab"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            android:key="ui_show_function_keys"
            android:title="Show Function Key Row"
            android:summary="Display the custom F1-F12 / arrow row in terminals"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="volume_keys_font_size"
            android:title="Volume Keys Control Font"
            android:summary="Use volume up/down to increase/decrease font size"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="detect_urls"
            android:title="Detect URLs"
            android:summary="Enable clickable URLs in terminal (long press to open)"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="show_performance_overlay"
            android:title="Show Performance Overlay"
            android:summary="Display CPU, memory, battery, and network stats"
            android:defaultValue="false" />
        
        <SwitchPreferenceCompat
            android:key="enable_custom_gestures"
            android:title="Custom Gestures"
            android:summary="Enable multi-touch gestures for tmux/screen shortcuts"
            android:defaultValue="false" />
        
        <ListPreference
            android:key="gesture_multiplexer_type"
            android:title="Multiplexer Type"
            android:summary="Select tmux, screen, or zellij for gesture commands"
            android:entries="@array/multiplexer_type_entries"
            android:entryValues="@array/multiplexer_type_values"
            android:defaultValue="tmux"
            android:dependency="enable_custom_gestures"
            app:useSimpleSummaryProvider="true" />
        
        <EditTextPreference
            android:key="multiplexer_custom_prefix"
            android:title="Custom Prefix Key"
            android:summary="Override default prefix (e.g., C-a, C-Space, ` - leave empty for default)"
            android:dialogMessage="Enter custom prefix key notation:\n\nExamples:\n• C-a or ^a → Ctrl+A\n• C-b or ^b → Ctrl+B\n• C-Space → Ctrl+Space\n• ` → Backtick\n• M-b → Alt+B\n• 0x02 → Hex value\n\nLeave empty to use multiplexer default."
            android:defaultValue=""
            android:dependency="enable_custom_gestures"
            android:inputType="text" />
        
        <SwitchPreferenceCompat
            android:key="auto_record_sessions"
            android:title="Auto-Record Sessions"
            android:summary="Automatically record all SSH sessions to transcripts"
            android:defaultValue="false" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="Custom Keyboard"
        android:key="category_custom_keyboard">

        <ListPreference
            android:key="keyboard_row_count"
            android:title="Keyboard Rows"
            android:summary="Number of rows in the custom keyboard (1-5)"
            android:entries="@array/keyboard_row_entries"
            android:entryValues="@array/keyboard_row_values"
            android:defaultValue="3"
            app:useSimpleSummaryProvider="true" />

        <Preference
            android:key="customize_keyboard_layout"
            android:title="Customize Keyboard Layout"
            android:summary="Add, remove, or reorder keyboard keys"
            android:icon="@drawable/ic_keyboard" />

        <Preference
            android:key="reset_keyboard_layout"
            android:title="Reset Keyboard Layout"
            android:summary="Restore default keyboard configuration" />

    </PreferenceCategory>

</PreferenceScreen>
