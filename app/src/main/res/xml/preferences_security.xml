<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="App Security"
        android:key="category_app_security">

        <SwitchPreferenceCompat
            android:key="security_lock_enabled"
            android:title="Security Lock"
            android:summary="Lock app after period of inactivity"
            android:defaultValue="false" />

        <ListPreference
            android:key="security_lock_timeout"
            android:title="Lock Timeout"
            android:summary="Time before app locks"
            android:entries="@array/lock_timeout_entries"
            android:entryValues="@array/lock_timeout_values"
            android:defaultValue="300"
            android:dependency="security_lock_enabled"
            app:useSimpleSummaryProvider="true" />

        <SwitchPreferenceCompat
            android:key="biometric_auth"
            android:title="Biometric Authentication"
            android:summary="Use fingerprint or face unlock"
            android:defaultValue="false"
            android:dependency="security_lock_enabled" />

        <!-- Wave 3.2 — PIN code app lock (independent of biometric/inactivity) -->
        <Preference
            android:key="app_lock_pin_setup"
            android:title="App lock PIN"
            android:summary="Prompt for PIN on app launch (set / change / disable)" />

        <!-- Wave 8.3 — FIDO2 / U2F detection (alpha; not wired to SSH auth) -->
        <Preference
            android:key="fido2_detector"
            android:title="FIDO2 hardware (Alpha)"
            android:summary="Detect connected security keys (YubiKey, SoloKey, …). SSH auth via these keys is NOT yet implemented." />

        <SwitchPreferenceCompat
            android:key="security_prevent_screenshots"
            android:title="Block Screenshots"
            android:summary="Prevent screenshots and screen recording in the app"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            android:key="security_auto_lock_background"
            android:title="Lock When Backgrounded"
            android:summary="Require unlock after returning from background"
            android:defaultValue="false" />

        <ListPreference
            android:key="security_auto_lock_timeout"
            android:title="Background Lock Timeout"
            android:summary="How long backgrounded before requiring unlock"
            android:entries="@array/lock_timeout_entries"
            android:entryValues="@array/lock_timeout_values"
            android:defaultValue="300"
            android:dependency="security_auto_lock_background"
            app:useSimpleSummaryProvider="true" />

        <ListPreference
            android:key="security_clear_clipboard_timeout"
            android:title="Auto-Clear Clipboard"
            android:summary="Clear clipboard after copying from terminal"
            android:entries="@array/clipboard_timeout_entries"
            android:entryValues="@array/clipboard_timeout_values"
            android:defaultValue="0"
            app:useSimpleSummaryProvider="true" />

    </PreferenceCategory>

    <PreferenceCategory
        android:title="SSH Security"
        android:key="category_ssh_security">

        <Preference
            android:key="clear_known_hosts"
            android:title="Clear known hosts"
            android:summary="Wipe previously seen host keys/fingerprints" />

        <SwitchPreferenceCompat
            android:key="ssh_agent_forwarding"
            android:title="SSH Agent Forwarding"
            android:summary="Forward authentication agent connections"
            android:defaultValue="false" />

        <SwitchPreferenceCompat
            android:key="strict_host_key_checking"
            android:title="Strict Host Key Checking"
            android:summary="Always verify host keys"
            android:defaultValue="true" />

        <SwitchPreferenceCompat
            android:key="port_knock_enabled_default"
            android:title="Enable Port Knocking by Default"
            android:summary="Execute port knock sequences for new connections (Default: OFF)"
            android:defaultValue="false" />

    </PreferenceCategory>

</PreferenceScreen>
